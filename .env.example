# ─── Stellar Network ───────────────────────────────────────────────────────────
# Must be one of: testnet | mainnet | futurenet
STELLAR_NETWORK=testnet

# Horizon REST API endpoint
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ─── Agent Identity ─────────────────────────────────────────────────────────────
# AGENT_SECRET_KEY  — 56-char Stellar secret (starts with S).
#                     Load from a secrets manager in production.
#                     NEVER commit a real key to version control.
AGENT_SECRET_KEY=SBPTNBEQQVQD5NIPZTCXHKM5ZVONK2ENLP5DTZJBGSUPOPWQSIFWZKX

# AGENT_PUBLIC_KEY  — Optional. If set, must match the key derived from
#                     AGENT_SECRET_KEY. Useful for double-checking identity.
# AGENT_PUBLIC_KEY=G...

# ─── x402 / PayFi ───────────────────────────────────────────────────────────────
# Asset used for machine-to-machine payments
X402_ASSET_CODE=USDC
X402_ASSET_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# Maximum amount the agent is allowed to spend per payment (in X402_ASSET_CODE).
# On mainnet this is hard-capped at 10,000 as a safety guard.
AGENT_SPENDING_LIMIT=100

# ─── Retry Config ───────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_MS=1500
